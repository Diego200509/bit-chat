PORT=3001
MONGO_URI=mongodb://localhost:27017/talkapp
JWT_SECRET=cambiar-por-una-clave-segura-en-produccion
CORS_ORIGIN=*

# Recuperación de contraseña: URL base del frontend (para el enlace del correo)
FRONTEND_URL=http://localhost:5173
# RESET_PASSWORD_EXPIRES_MINUTES=60

# Envío de correos (opcional). Si no configuras SMTP, el enlace se imprime en consola (desarrollo).
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=tu@gmail.com, SMTP_PASS=contraseña-de-aplicación
# Mailtrap (pruebas): crea cuenta en mailtrap.io y usa host/user/pass del inbox
# Resend/SendGrid/Mailgun: usa el SMTP que te den al crear la cuenta
# EMAIL_FROM=TalkApp <noreply@tudominio.com>
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
